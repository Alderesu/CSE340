<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <h2><%= projectDetails.title %></h2>
    <p><%= projectDetails.description %></p>
    <p><strong>Date:</strong> <%= projectDetails.project_date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
    <p><strong>Location:</strong> <%= projectDetails.location %></p>
    <p><strong>Organization:</strong>
        <a href="/organization/<%= projectDetails.organization_id %>"><%= projectDetails.organization_name %></a>
    </p>

    <h3>Categories</h3>
    <ul class="tag-list">
        <% categories.forEach(category => { %>
            <li class="tag"><a href="/category/<%= category.category_id %>"><%= category.name %></a></li>
        <% }); %>
    </ul>
</main>
<%- include('partials/footer') %>

<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>Browse the different categories of service opportunities available across our network.</p>
    <ul class="card-grid">
        <% categories.forEach(category => { %>
            <li class="card">
                <h2><a href="/category/<%= category.category_id %>"><%= category.name %></a></h2>
                <p><a href="/edit-category/<%= category.category_id %>">Edit</a></p>
            </li>
        <% }); %>
    </ul>

    <p><a href="/new-category">Add a new category</a></p>
</main>
<%- include('partials/footer') %>

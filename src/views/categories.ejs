<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>Browse the different categories of service opportunities available across our network.</p>
    <ul class="card-grid">
        <% categories.forEach(category => { %>
            <li class="card">
                <h2><%= category.name %></h2>
            </li>
        <% }); %>
    </ul>
</main>
